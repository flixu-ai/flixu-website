---
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

// Navigation tabs — Anthropic-style, centered in header
const tabs = [
  { label: 'Developer Guide', href: '/docs/developer-guide/introduction/' },
  { label: 'API Reference',   href: '/docs/api-reference/overview/' },
  { label: 'Resources',       href: '/docs/resources/overview/' },
  { label: 'Release Notes',   href: '/docs/release-notes/overview/' },
];

// Determine active tab from current URL
const currentPath = Astro.url.pathname;
const activeTab = tabs.find(tab => {
  const section = tab.href.split('/')[2];
  return currentPath.includes(`/${section}/`);
})?.href || tabs[0].href;
---

<div class="header sl-flex">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <nav class="header-tabs" aria-label="Documentation sections">
    {tabs.map(tab => (
      <a
        href={tab.href}
        class:list={['header-tab', { active: activeTab === tab.href }]}
      >
        {tab.label}
      </a>
    ))}
  </nav>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex search-wrapper print:hidden">
      {shouldRenderSearch && <Search />}
    </div>
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
  </div>
</div>

<style>
  /* CRITICAL: Starlight's page layout depends on the header's @layer starlight.core
     grid template to position the sidebar and content columns correctly. */
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }

    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    .right-group,
    .social-icons {
      gap: 1rem;
      align-items: center;
    }

    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }
      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }
      .header {
        --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
        --__main-column-fr: calc(
          (
              100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
                (2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
                var(--sl-content-width)
            ) / 2
        );
        display: grid;
        grid-template-columns:
          minmax(
            calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))),
            auto
          )
          1fr
          auto;
        align-content: center;
      }
    }
  }

  /* ── Tabs — centered in middle column ────────────────────────── */
  .header-tabs {
    display: none;
    align-items: center;
    gap: 0.25rem;
    justify-content: center;
  }

  @media (min-width: 50rem) {
    .header-tabs {
      display: flex;
    }
  }

  .header-tab {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    color: #78716c;
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    transition: color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .header-tab:hover {
    color: #1c1917;
    background: rgba(0, 0, 0, 0.04);
  }

  .header-tab.active {
    color: #1c1917;
    font-weight: 500;
    background: #e7e5e4;
  }

  /* ── Right group ─────────────────────────────────────────────── */
  .right-group {
    gap: 0.75rem;
    align-items: center;
    flex-shrink: 0;
  }

  .search-wrapper {
    align-items: center;
  }

  .social-icons {
    gap: 0.75rem;
    align-items: center;
  }
</style>
