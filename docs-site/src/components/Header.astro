---
import config from 'virtual:starlight/user-config';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';

// Navigation tabs — Anthropic-style, centered in header
const tabs = [
  { label: 'Developer Guide', href: '/docs/developer-guide/introduction/' },
  { label: 'API Reference',   href: '/docs/api-reference/overview/' },
  { label: 'Resources',       href: '/docs/resources/overview/' },
  { label: 'Release Notes',   href: '/docs/release-notes/overview/' },
];

// Determine active tab from current URL
const currentPath = Astro.url.pathname;
const activeTab = tabs.find(tab => {
  const section = tab.href.split('/')[2];
  return currentPath.includes(`/${section}/`);
})?.href || tabs[0].href;
---

<div class="header sl-flex">
  <div class="title-wrapper">
    <SiteTitle />
  </div>
  <nav class="header-tabs" aria-label="Documentation sections">
    {tabs.map(tab => (
      <a
        href={tab.href}
        class:list={['header-tab', { active: activeTab === tab.href }]}
      >
        {tab.label}
      </a>
    ))}
  </nav>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
  </div>
</div>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0;
    gap: 1rem;
  }

  .title-wrapper {
    flex-shrink: 0;
    overflow: clip;
    padding: 0.25rem;
    margin: -0.25rem;
  }

  /* ── Tabs — centered in header ───────────────────────────────── */
  .header-tabs {
    display: none;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
    justify-content: center;
  }

  @media (min-width: 50rem) {
    .header-tabs {
      display: flex;
    }
  }

  .header-tab {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    color: #78716c;
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    transition: color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .header-tab:hover {
    color: #1c1917;
    background: rgba(0, 0, 0, 0.04);
  }

  .header-tab.active {
    color: #C2410C;
    font-weight: 500;
    background: rgba(194, 65, 12, 0.06);
  }

  /* ── Right group ─────────────────────────────────────────────── */
  .right-group,
  .social-icons {
    gap: 0.75rem;
    align-items: center;
    flex-shrink: 0;
  }
</style>
