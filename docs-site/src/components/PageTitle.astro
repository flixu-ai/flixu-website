---
/**
 * Custom PageTitle with "Copy page" button.
 * Copies page content as clean Markdown for agentic coding IDEs.
 */
const PAGE_TITLE_ID = '_top';

const title = Astro.locals.starlightRoute.entry.data.title;
const slug = Astro.locals.starlightRoute.slug;
const githubRawUrl = `https://raw.githubusercontent.com/flixu-ai/flixu-website/main/docs-site/src/content/docs/${slug}.mdx`;
---

<div class="page-title-row">
  <h1 id={PAGE_TITLE_ID}>{title}</h1>
  <div class="copy-page-wrapper">
    <button class="copy-page-btn" id="copy-page-btn" aria-label="Copy page as Markdown">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M11 5V3.5A1.5 1.5 0 0 0 9.5 2h-6A1.5 1.5 0 0 0 2 3.5v6A1.5 1.5 0 0 0 3.5 11H5" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      <span class="copy-label">Copy page</span>
      <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <div class="copy-dropdown" id="copy-dropdown" hidden>
      <button class="dropdown-item" id="copy-markdown-btn">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M11 5V3.5A1.5 1.5 0 0 0 9.5 2h-6A1.5 1.5 0 0 0 2 3.5v6A1.5 1.5 0 0 0 3.5 11H5" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Copy page as Markdown
      </button>
      <a class="dropdown-item" href={githubRawUrl} target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 2h8v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M14 2L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M10 2H3.5A1.5 1.5 0 0 0 2 3.5v9A1.5 1.5 0 0 0 3.5 14h9a1.5 1.5 0 0 0 1.5-1.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Open Markdown
      </a>
    </div>
  </div>
</div>

<script is:inline>
  function initCopyButton() {
    const btn = document.getElementById('copy-page-btn');
    const dropdown = document.getElementById('copy-dropdown');
    const copyBtn = document.getElementById('copy-markdown-btn');

    if (!btn || !dropdown || !copyBtn) return;

    // Prevent duplicate listeners
    if (btn.dataset.initialized) return;
    btn.dataset.initialized = 'true';

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.hidden = !dropdown.hidden;
    });

    document.addEventListener('click', (e) => {
      if (!btn.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.hidden = true;
      }
    });

    copyBtn.addEventListener('click', async () => {
      const content = document.querySelector('.sl-markdown-content');
      if (!content) return;

      const title = document.querySelector('h1')?.textContent || '';
      let markdown = '# ' + title + '\n\n';

      const elements = content.querySelectorAll('h2, h3, h4, h5, h6, p, ul, ol, pre, table, blockquote, hr');
      elements.forEach((el) => {
        const tag = el.tagName.toLowerCase();
        if (tag.startsWith('h')) {
          const level = parseInt(tag[1]);
          markdown += '#'.repeat(level) + ' ' + el.textContent.trim() + '\n\n';
        } else if (tag === 'p') {
          markdown += el.textContent.trim() + '\n\n';
        } else if (tag === 'ul') {
          el.querySelectorAll(':scope > li').forEach(function(li) {
            markdown += '- ' + li.textContent.trim() + '\n';
          });
          markdown += '\n';
        } else if (tag === 'ol') {
          var i = 1;
          el.querySelectorAll(':scope > li').forEach(function(li) {
            markdown += i + '. ' + li.textContent.trim() + '\n';
            i++;
          });
          markdown += '\n';
        } else if (tag === 'pre') {
          var code = el.querySelector('code');
          var lang = code?.className?.replace('language-', '') || '';
          markdown += '```' + lang + '\n' + (code?.textContent || el.textContent) + '```\n\n';
        } else if (tag === 'blockquote') {
          markdown += '> ' + el.textContent.trim() + '\n\n';
        } else if (tag === 'hr') {
          markdown += '---\n\n';
        } else if (tag === 'table') {
          var rows = el.querySelectorAll('tr');
          rows.forEach(function(row, idx) {
            var cells = row.querySelectorAll('th, td');
            var line = Array.from(cells).map(function(c) { return c.textContent.trim(); }).join(' | ');
            markdown += '| ' + line + ' |\n';
            if (idx === 0) {
              markdown += '| ' + Array.from(cells).map(function() { return '---'; }).join(' | ') + ' |\n';
            }
          });
          markdown += '\n';
        }
      });

      try {
        await navigator.clipboard.writeText(markdown.trim());
        var label = btn.querySelector('.copy-label');
        if (label) {
          var original = label.textContent;
          label.textContent = 'Copied!';
          setTimeout(function() { label.textContent = original; }, 2000);
        }
      } catch (err) {
        console.error('Failed to copy:', err);
      }

      dropdown.hidden = true;
    });
  }

  // Run immediately if DOM is ready, otherwise wait
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCopyButton);
  } else {
    initCopyButton();
  }
</script>

<style>
  @layer starlight.core {
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 400;
      font-family: 'Instrument Serif', Georgia, serif;
      color: #1c1917;
      letter-spacing: -0.025em;
    }
  }

  .page-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .copy-page-wrapper {
    position: relative;
    flex-shrink: 0;
    margin-top: 1.25rem;
  }

  .copy-page-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 400;
    color: #78716c;
    background: transparent;
    border: 1px solid #d6d3d1;
    border-radius: 6px;
    padding: 0.375rem 0.625rem;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .copy-page-btn:hover {
    color: #1c1917;
    border-color: #a8a29e;
    background: #f5f5f4;
  }

  .chevron {
    margin-left: 0.125rem;
  }

  .copy-dropdown {
    position: absolute;
    top: calc(100% + 0.375rem);
    right: 0;
    z-index: 100;
    min-width: 14rem;
    background: #ffffff;
    border: 1px solid #e7e5e4;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08), 0 1px 4px rgba(0, 0, 0, 0.04);
    padding: 0.375rem;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: #44403c;
    background: transparent;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.1s ease;
    white-space: nowrap;
  }

  .dropdown-item:hover {
    background: #f5f5f4;
    color: #1c1917;
  }

  @media (max-width: 30rem) {
    .copy-page-wrapper {
      display: none;
    }
  }
</style>
