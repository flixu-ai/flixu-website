---
import BaseLayout from "./BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import { ArrowRight } from "lucide-react";
import Breadcrumbs from "../components/seo/Breadcrumbs.astro";
import FAQSection from "../components/seo/FAQSection.astro";
import LastUpdated from "../components/seo/LastUpdated.astro";
import SchemaOrg from "../components/seo/SchemaOrg.astro";
import { getLocalizedPath, useTranslations } from "../i18n/utils";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    publishDate: Date;
    dateModified?: Date;
    tldr?: string;
    faqs?: Array<{ question: string; answer: string }>;
  };
  lang: string;
}

const { frontmatter, lang } = Astro.props;
const t = await useTranslations(lang);

const baseArticle = {
  "@type": "Article",
  headline: frontmatter.title,
  description: frontmatter.description,
  author: {
    "@type": "Person",
    name: "Deniz Wozniak",
    url: "https://flixu.ai/about",
  },
  publisher: {
    "@type": "Organization",
    name: "Flixu",
    url: "https://flixu.ai",
  },
  datePublished: frontmatter.publishDate.toISOString(),
  ...(frontmatter.dateModified && {
    dateModified: new Date(frontmatter.dateModified).toISOString(),
  }),
};

// Create a combined @graph schema to allow multiple root objects
const articleSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@graph": [baseArticle],
};

// Inject FAQPage if FAQs exist
if (frontmatter.faqs && frontmatter.faqs.length > 0) {
  articleSchema["@graph"].push({
    "@type": "FAQPage",
    mainEntity: frontmatter.faqs.map(
      (faq: { question: string; answer: string }) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      }),
    ),
  });
}

const breadcrumbItems = [
  { name: "Home", url: getLocalizedPath("/", lang) },
  {
    name: t.comparison?.preTitle || "Compare",
    url: getLocalizedPath("/compare", lang),
  },
  { name: frontmatter.title, url: Astro.url.pathname },
];
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  chapter="Market"
  ogType="article"
>
  <SchemaOrg schema={articleSchema} slot="schema" />

  <!-- HERO -->
  <Section data-chapter="01 — INTRO" class="hero-section">
    <div class="max-w-4xl">
      <Breadcrumbs items={breadcrumbItems} />
      <span class="badge">{t.comparison.preTitle}</span>
      <h1 class="hero-title">{frontmatter.title}</h1>
      <p class="hero-desc max-w-2xl">{frontmatter.description}</p>

      {
        frontmatter.dateModified && (
          <div class="mt-6">
            <LastUpdated
              date={new Date(frontmatter.dateModified)}
              lang={lang}
            />
          </div>
        )
      }
    </div>
  </Section>

  <!-- CONTENT -->
  <Section data-chapter="02 — METRICS" class="content-section">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      <!-- MAIN ARTICLE -->
      <div class="lg:col-span-8">
        <article class="prose-secondary">
          <slot />
        </article>

        {
          frontmatter.faqs && frontmatter.faqs.length > 0 && (
            <FAQSection items={frontmatter.faqs} />
          )
        }
      </div>

      <!-- SIDEBAR -->
      <aside class="lg:col-span-4">
        <div class="sticky top-32">
          <div class="p-8 bg-paper border border-stone-200 rounded-sm">
            <h3 class="cta-box-title mb-4">{t.comparison.whyTitle}</h3>
            <p class="text-stone-600 mb-8 leading-relaxed">
              {t.comparison.whyDesc}
            </p>

            <div class="space-y-4">
              <a href={getLocalizedPath("/pricing", lang)} class="link-card">
                <span class="link-card-label">
                  {t.comparison.ctaPricing}
                </span>
                <ArrowRight
                  size={18}
                  className="text-stone-400 group-hover:text-orange-700 transition-transform group-hover:translate-x-1"
                />
              </a>
              <a
                href={getLocalizedPath("/signup", lang)}
                class="link-card border-orange-700/30 hidden"
              >
                <span class="font-medium text-orange-700">
                  {t.comparison.ctaTrial}
                </span>
                <ArrowRight
                  size={18}
                  className="text-orange-700 transition-transform group-hover:translate-x-1"
                />
              </a>
            </div>
          </div>

          <div class="mt-8 p-8 border-l-2 border-stone-200 bg-stone-50/10">
            <p class="text-sm text-stone-500 font-serif italic leading-relaxed">
              {t.comparison.disclaimer}
            </p>
          </div>
        </div>
      </aside>
    </div>
  </Section>
</BaseLayout>
