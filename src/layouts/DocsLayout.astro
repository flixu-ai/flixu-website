---
import BaseLayout from "./BaseLayout.astro";
import DocSearch from "../components/docs/DocSearch.jsx";
import OnPageNav from "../components/docs/OnPageNav.astro";
import CopyMarkdownButton from "../components/docs/CopyMarkdownButton.jsx";
import { getCollection, type CollectionEntry } from "astro:content";

interface Props {
    title: string;
    description?: string;
    headings?: { depth: number; slug: string; text: string }[];
    rawContent?: string;
}

const { title, description, headings, rawContent } = Astro.props;

const { lang } = Astro.params;
const currentLang = lang || "en"; // Fallback for root /docs which has no param

// Fetch and group docs for sidebar
const allDocs = await getCollection("docs");

// Filter docs by current language
const localizedDocs = allDocs.filter((d) =>
    d.slug.startsWith(`${currentLang}/`),
);

const sortedDocs = localizedDocs.sort(
    (a: CollectionEntry<"docs">, b: CollectionEntry<"docs">) =>
        a.data.order - b.data.order,
);
const groupedDocs = sortedDocs.reduce(
    (
        acc: Record<string, CollectionEntry<"docs">[]>,
        doc: CollectionEntry<"docs">,
    ) => {
        const section = doc.data.section;
        if (!acc[section]) acc[section] = [];
        acc[section].push(doc);
        return acc;
    },
    {},
);

function getCleanSlug(slug: string, lang: string) {
    if (lang === "en" && !slug.startsWith("en/")) return slug; // Handle case where slug might already be clean or different
    return slug.replace(new RegExp(`^${lang}/`), "");
}
---

<BaseLayout title={title} description={description}>
    <div
        class="max-w-[1400px] mx-auto px-6 md:px-12 xl:px-24 pt-32 pb-24 grid grid-cols-1 lg:grid-cols-12 gap-12"
    >
        {/* Sidebar (Desktop) */}
        <aside
            class="hidden lg:block lg:col-span-3 xl:col-span-2 sticky top-32 self-start h-[calc(100vh-10rem)] overflow-y-auto pr-6"
        >
            <div class="mb-8">
                <DocSearch client:load />
            </div>

            <nav class="flex flex-col gap-8">
                {
                    Object.entries(groupedDocs).map(([section, docs]) => (
                        <div>
                            <h4 class="font-mono text-xs uppercase tracking-widest text-stone-900 mb-4">
                                {section}
                            </h4>
                            <ul class="flex flex-col gap-2">
                                {/* @ts-ignore */}
                                {docs.map((doc: CollectionEntry<"docs">) => (
                                    <li>
                                        <a
                                            href={
                                                currentLang === "en" && !lang
                                                    ? `/docs/${getCleanSlug(doc.slug, currentLang)}`
                                                    : `/${currentLang}/docs/${getCleanSlug(doc.slug, currentLang)}`
                                            }
                                            class={`text-sm font-sans transition-colors ${Astro.url.pathname.includes(getCleanSlug(doc.slug, currentLang)) ? "text-orange-700 font-medium" : "text-stone-500 hover:text-stone-900"}`}
                                        >
                                            {doc.data.title}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </nav>
        </aside>

        {/* Main Content */}
        <main class="col-span-1 lg:col-span-9 xl:col-span-8 min-w-0">
            <div
                class="flex items-center justify-between mb-8 pb-4 border-b border-stone-200"
            >
                <h1 class="font-serif text-4xl text-stone-900">{title}</h1>
                {
                    rawContent && (
                        <CopyMarkdownButton client:load content={rawContent} />
                    )
                }
            </div>

            <article
                class="prose prose-stone prose-lg max-w-none prose-headings:font-serif prose-a:text-orange-700 hover:prose-a:text-orange-800 prose-pre:bg-[#FDFCF8] prose-pre:border prose-pre:border-stone-200 prose-pre:text-stone-800"
            >
                <slot />
            </article>
        </main>

        {/* Right Sidebar (TOC) */}
        <aside class="hidden xl:block xl:col-span-2 relative">
            {headings && <OnPageNav headings={headings} />}
        </aside>
    </div>
</BaseLayout>
