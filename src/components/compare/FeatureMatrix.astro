---
import { Check, Minus } from "lucide-react";

interface Row {
    feature: string;
    flixu: string;
    competitor: string;
}

interface Props {
    competitorName: string;
    rows?: Row[];
}

const { competitorName, rows: customRows } = Astro.props;

const defaultRows: Row[] = [
    {
        feature: "Setup Time",
        flixu: "Instant (API/Browser)",
        competitor: "Months of Implementation",
    },
    {
        feature: "Context Awareness",
        flixu: "Native Real-time Context",
        competitor: "Static Glossary Only",
    },
    {
        feature: "Pricing Model",
        flixu: "Value/Asset Based",
        competitor: "Seat-based / Per User",
    },
    {
        feature: "Data Privacy",
        flixu: "Enterprise-grade Isolation",
        competitor: "Public Cloud Training",
    },
];

const displayRows = customRows || defaultRows;
---

<div
    class="my-12 overflow-hidden border border-stone-200 rounded-sm bg-[#FDFCF8]"
>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[600px]">
            <thead>
                <tr class="bg-stone-50 border-b border-stone-200">
                    <th
                        class="py-6 px-8 font-mono text-xs uppercase tracking-widest text-stone-400 w-1/3"
                        >Feature</th
                    >
                    <th
                        class="py-6 px-8 font-serif text-xl text-stone-900 w-1/3 bg-orange-50/30"
                        >Flixu</th
                    >
                    <th
                        class="py-6 px-8 font-serif text-xl text-stone-900 w-1/3"
                        >{competitorName}</th
                    >
                </tr>
            </thead>
            <tbody>
                {
                    displayRows.map((row) => (
                        <tr class="border-b border-stone-100 last:border-none group hover:bg-stone-50/50 transition-colors">
                            <td class="py-6 px-8 font-medium text-stone-800">
                                {row.feature}
                            </td>
                            <td class="py-6 px-8 bg-orange-50/10">
                                <div class="flex items-center gap-3">
                                    <span class="p-1 rounded-full bg-green-100 text-green-700">
                                        <Check size={14} strokeWidth={3} />
                                    </span>
                                    <span class="text-stone-900 font-medium">
                                        {row.flixu}
                                    </span>
                                </div>
                            </td>
                            <td class="py-6 px-8">
                                <div class="flex items-center gap-3">
                                    <span class="p-1 rounded-full bg-stone-100 text-stone-400">
                                        <Minus size={14} strokeWidth={3} />
                                    </span>
                                    <span class="text-stone-500">
                                        {row.competitor}
                                    </span>
                                </div>
                            </td>
                        </tr>
                    ))
                }
            </tbody>
        </table>
    </div>
</div>
