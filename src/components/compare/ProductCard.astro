---
import { PlusCircle, MinusCircle, ExternalLink } from "lucide-react";

interface Props {
    name: string;
    badge?: string;
    pros: string[];
    cons: string[];
    isFlixu?: boolean;
    link?: string;
}

const { name, badge, pros, cons, isFlixu = false, link } = Astro.props;
---

<div
    class={`group relative p-10 border transition-all duration-500 rounded-sm mb-12 ${
        isFlixu
            ? "bg-orange-50/10 border-orange-700/60"
            : "bg-[#FDFCF8] border-stone-200"
    }`}
>
    <div class="flex items-start justify-between mb-10">
        <div class="flex flex-col gap-6 items-start">
            {
                isFlixu && (
                    <div class="font-mono text-[10px] uppercase tracking-widest text-white bg-orange-700 px-3 py-1 inline-block">
                        Category Leader 2026
                    </div>
                )
            }
            <div>
                <h3 class="font-serif text-4xl text-stone-900 tracking-tight">
                    {name}
                </h3>
                {
                    isFlixu && (
                        <p class="text-orange-700 text-xs mt-2 font-mono uppercase tracking-wider">
                            Architectural Orchestration Layer
                        </p>
                    )
                }
            </div>
        </div>
        {
            badge && (
                <span class="font-mono text-[10px] uppercase tracking-widest px-4 py-1.5 rounded-full border border-stone-200 bg-stone-50 text-stone-500 whitespace-nowrap">
                    {badge}
                </span>
            )
        }
    </div>

    <div
        class={`grid grid-cols-1 md:grid-cols-2 gap-0 ${isFlixu ? "divide-x divide-orange-700/10" : "divide-x divide-stone-100"}`}
    >
        <div class="pr-8">
            <h4
                class="font-mono text-[10px] uppercase tracking-widest text-stone-400 mb-6"
            >
                Strengths
            </h4>
            <ul class="space-y-4">
                {
                    pros.map((pro) => (
                        <li class="flex items-start gap-3 text-stone-800 text-base leading-relaxed">
                            <PlusCircle
                                size={16}
                                className="text-green-600 shrink-0 mt-1 opacity-60"
                            />
                            <span>{pro}</span>
                        </li>
                    ))
                }
            </ul>
        </div>
        <div class="pl-8">
            <h4
                class="font-mono text-[10px] uppercase tracking-widest text-stone-400 mb-6"
            >
                Limitations
            </h4>
            <ul class="space-y-4">
                {
                    cons.map((con) => (
                        <li class="flex items-start gap-3 text-stone-600 text-base leading-relaxed">
                            <MinusCircle
                                size={16}
                                className="text-stone-300 shrink-0 mt-1 opacity-60"
                            />
                            <span>{con}</span>
                        </li>
                    ))
                }
            </ul>
        </div>
    </div>

    {
        link && (
            <div
                class={`mt-12 pt-10 border-t flex justify-end ${isFlixu ? "border-orange-700/10" : "border-stone-100"}`}
            >
                <a
                    href={link}
                    class={`not-prose px-8 py-4 rounded-sm text-sm font-medium transition-all duration-300 flex items-center gap-3 no-underline ${
                        isFlixu
                            ? "bg-orange-700 !text-white hover:bg-orange-800"
                            : "bg-white border border-stone-200 !text-stone-900 hover:border-stone-400"
                    }`}
                >
                    <span>
                        {isFlixu ? "Explore Capability" : "Visit Provider"}
                    </span>
                    <ExternalLink size={16} />
                </a>
            </div>
        )
    }
</div>
