---
interface Heading {
    depth: number;
    slug: string;
    text: string;
}

interface Props {
    headings: Heading[];
}

const { headings } = Astro.props;
---

<div class="hidden xl:block fixed right-8 top-32 w-48">
    <h5
        class="font-mono text-[10px] uppercase tracking-widest text-stone-400 mb-4"
    >
        On this page
    </h5>
    <ul class="space-y-2 border-l border-stone-200">
        {
            headings.map((heading: Heading) => (
                <li class={`pl-3 ${heading.depth === 3 ? "ml-2" : ""}`}>
                    <a
                        href={`#${heading.slug}`}
                        class="block text-sm text-stone-500 hover:text-orange-700 transition-colors line-clamp-1"
                    >
                        {heading.text}
                    </a>
                </li>
            ))
        }
    </ul>
</div>
