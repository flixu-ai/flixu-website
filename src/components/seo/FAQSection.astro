---
/**
 * FAQ section with accessible expand/collapse + FAQPage JSON-LD schema.
 * Each FAQ item renders as a <details> element for native accessibility.
 * Usage: <FAQSection items={[{ question: "...", answer: "..." }]} />
 */
import SchemaOrg from "./SchemaOrg.astro";

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
}

const { items, title = "Frequently Asked Questions" } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<section class="mt-16 pt-16 border-t border-stone-100">
  <h2 class="font-serif text-3xl md:text-4xl text-stone-900 mb-10">
    {title}
  </h2>

  <div class="space-y-0 divide-y divide-stone-100">
    {
      items.map((item) => (
        <details class="group py-6">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <h3 class="font-serif text-lg text-stone-900 group-open:text-orange-700 transition-colors pr-8">
              {item.question}
            </h3>
            <span class="shrink-0 text-stone-400 group-open:text-orange-700 transition-transform group-open:rotate-45 text-xl">
              +
            </span>
          </summary>
          <p class="mt-4 text-stone-600 leading-relaxed max-w-3xl">
            {item.answer}
          </p>
        </details>
      ))
    }
  </div>
</section>

<SchemaOrg schema={faqSchema} />
