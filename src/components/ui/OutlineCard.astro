---
import * as LucideIcons from "lucide-react";
import FeatureVisual from "../widget/FeatureVisual";
const { title, icon, visualVariant } = Astro.props;
// @ts-ignore
const IconComponent = LucideIcons[icon] || LucideIcons.HelpCircle;
---

<div
  class="group relative h-full bg-[#FDFCF8] border border-stone-200 hover:border-orange-700/30 transition-colors duration-500 flex flex-col overflow-hidden"
>
  <!-- Architectural Corner Accent -->
  <div
    class="absolute top-0 right-0 w-[1px] h-3 bg-orange-700 opacity-0 group-hover:opacity-100 transition-opacity"
  >
  </div>
  <div
    class="absolute top-0 right-0 w-3 h-[1px] bg-orange-700 opacity-0 group-hover:opacity-100 transition-opacity"
  >
  </div>

  <!-- Content Area -->
  <div class="p-8 pb-0 flex-grow relative z-20">
    <div class="mb-6 text-orange-700">
      <IconComponent size={24} strokeWidth={1.5} />
    </div>
    <h3 class="mb-3">{title}</h3>
    <p>
      <slot />
    </p>
  </div>

  <!-- The Animated Visual Area -->
  <div class="relative mt-auto -mb-4 z-10 w-full">
    <FeatureVisual client:visible variant={visualVariant || "text"} />
  </div>
</div>
