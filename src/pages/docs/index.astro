---
import { getCollection, type CollectionEntry } from "astro:content";

// Default locale is 'en', no static paths needed for root pages in Astro hybrid/static mode usually,
// but for explicit static generation of non-param routes, we just export logic.
// Actually, since this is 'src/pages/docs/index.astro', it handles '/docs'.

const docs = await getCollection("docs");
const enDocs = docs.filter((d) => d.slug.startsWith("en/"));
const firstDoc = enDocs.sort(
    (a: CollectionEntry<"docs">, b: CollectionEntry<"docs">) =>
        a.data.order - b.data.order,
)[0];
const cleanSlug = firstDoc.slug.replace(/^en\//, "");

return Astro.redirect(`/docs/${cleanSlug}`);
---
