---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Section from "../../../components/ui/Section.astro";
import { getCollection } from "astro:content";
import { useTranslations, locales, getLocalizedPath } from "../../../i18n/utils";
import Breadcrumbs from "../../../components/seo/Breadcrumbs.astro";
import SchemaOrg from "../../../components/seo/SchemaOrg.astro";

export const prerender = true;

export function getStaticPaths() {
    return locales.map(l => ({ params: { lang: l === "en" ? undefined : l } }));
}

let { lang } = Astro.params;
if (!lang) lang = "en";

const allTopics = await getCollection("topics");
const topics = allTopics.filter((topic) => {
    return topic.id.startsWith("en/");
});

function getCleanSlug(slug: string) {
    const parts = slug.split("/");
    return parts.length > 1 ? parts.slice(1).join("/") : slug;
}

const tGlobal = await useTranslations(lang);
const tNav = tGlobal.navigation as any;

const breadcrumbItems = [
  { name: tNav?.home?.title || "Home", url: getLocalizedPath("/", lang) },
  { name: tNav?.resources?.items?.topic?.title || "Topic Library", url: Astro.url.pathname },
];

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": topics.map((topic, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": `https://flixu.ai${getLocalizedPath(`/topic/${getCleanSlug(topic.slug)}`, lang)}`,
    "name": topic.data.title,
    "description": topic.data.description
  }))
};
---

<BaseLayout title={lang === "de" ? "Wissensdatenbank" : "Knowledge Base"} chapter="Knowledge">
    <SchemaOrg schema={itemListSchema} slot="schema" />
    <Section data-chapter={`01 — ${tGlobal.rail.topics.toUpperCase()}`} class="hub-hero">
        <div class="hub-grid-bg"></div>

        <header class="hub-header relative z-10">
            <div class="pl-6 md:pl-12 xl:pl-0">
               <Breadcrumbs items={breadcrumbItems} />
            </div>
            <h1 class="hub-title">
                {lang === "de" ? "Wissen." : "Knowledge Base."}
            </h1>
            <p class="hub-desc">
                {
                    lang === "de"
                        ? "Konzepte, Strategien und Technik hinter kontextueller KI."
                        : "Core concepts of contextual AI and translation strategy."
                }
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 relative z-10">
            {
                topics.map((topic, index) => (
                    <a
                        href={getLocalizedPath(`/topic/${getCleanSlug(topic.slug)}`, lang)}
                        class:list={[
                            "group card",
                            index === 0 ? "md:col-span-2 bg-stone-50/30" : "",
                        ]}
                    >
                        <div class="card-glow" />

                        <div class="flex justify-between items-start mb-6">
                            <span class="card-label">
                                {topic.data.category}
                            </span>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="text-stone-300 group-hover:text-orange-700 transition-all duration-300 group-hover:-translate-y-1 group-hover:translate-x-1"
                            >
                                <line x1="7" y1="17" x2="17" y2="7" />
                                <polyline points="7 7 17 7 17 17" />
                            </svg>
                        </div>

                        <h3
                            class:list={[
                                index === 0
                                    ? "card-title--lg"
                                    : "card-title",
                            ]}
                        >
                            {topic.data.title}
                        </h3>

                        <p class="card-desc max-w-md line-clamp-3">
                            {topic.data.description}
                        </p>

                        {index === 0 && (
                            <div class="mt-8 text-sm font-medium text-orange-700 opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
                                Read Analysis ->
                            </div>
                        )}
                    </a>
                ))
            }
        </div>
    </Section>
</BaseLayout>
