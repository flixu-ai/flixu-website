---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";
import TldrBlock from "../../components/seo/TldrBlock.astro";
import { getLocalizedPath, locales, useTranslations } from "../../i18n/utils";
import HeroVision from "../../components/visuals/HeroVision.jsx";
import { Check, ArrowRight } from "lucide-react";

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    ...locales.map((lang) => ({ params: { lang } })),
  ];
}

let { lang } = Astro.params;
if (!lang) lang = "en";

// @ts-ignore
const t = await useTranslations(lang);

const title = "Open Beta | Flixu Translate";
const description =
  "Welcome to the Flixu Translate Open Beta. Experience the world's most precise AI localization engine, designed specifically for SaaS and technical teams.";

const isDev = import.meta.env.DEV;
const appUrl = isDev ? "http://localhost:3000" : "https://app.flixu.ai";
const openBetaLink =
  import.meta.env.PUBLIC_OPEN_BETA_LINK ||
  `${appUrl}/sign-up?plan=individual&intent=betalist&interval=month`;
---

<BaseLayout title={title} description={description}>
  {/* SEO Schema */}
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: "Flixu Translate Open Beta",
      description:
        "Join the Flixu Translate Open Beta and test the next generation of AI translation natively.",
    })}
  />

  <Section data-chapter="01 — WELCOME" class="hero-section pb-16 pt-32">
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center max-w-7xl mx-auto px-6"
    >
      <div class="max-w-3xl !px-0">
        <div
          class="inline-flex flex-row items-center gap-2 mb-6 border border-green-200 bg-green-50 px-3 py-1 rounded-full"
        >
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          <span
            class="text-xs font-mono text-green-700 uppercase tracking-widest"
            >Public Beta is Live</span
          >
        </div>

        <h1 class="mb-6 font-serif">Welcome, BetaList Community.</h1>
        <p class="max-w-xl text-xl text-stone-600 mb-8 font-sans">
          You've found us early. Flixu is the precision translation engine built
          by founders, for founders. We are currently opening our architecture
          for public stress-testing and feedback.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={openBetaLink}
            class="inline-block px-8 py-3 bg-stone-900 text-white rounded-sm hover:-translate-y-0.5 hover:shadow-md transition-all font-medium text-center hidden"
          >
            Join the Open Beta
          </a>
          <a
            href="#details"
            class="inline-block px-8 py-3 bg-white border border-stone-200 text-stone-900 rounded-sm hover:-translate-y-0.5 hover:shadow-md transition-all font-medium text-center"
          >
            Read the Details
          </a>
        </div>
      </div>
      <div class="relative w-full aspect-[4/3] hidden lg:block">
        <HeroVision client:load />
      </div>
    </div>
  </Section>

  <Section
    id="details"
    data-chapter="02 — TL;DR"
    class="tldr-section bg-stone-50 py-16"
  >
    <div class="max-w-3xl mx-auto">
      <TldrBlock
        text="The Open Beta grants you full access to the Flixu Translate platform, including our Contextual Embeddings, Brand Voice controls, and Semantic Translation Memory. While in beta, we heavily subsidize the AI inference costs to allow rigorous testing. In exchange, we ask for your candid feedback and bug reports to help us refine the engine before our global launch."
      />
    </div>
  </Section>

  <Section data-chapter="03 — FEATURES" class="content-section py-24">
    <div class="max-w-4xl mx-auto">
      <h2 class="mb-12 text-center font-serif text-4xl">
        What you can test today.
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white p-8 rounded-sm border border-stone-200 shadow-sm">
          <h3 class="font-serif text-xl mb-3 flex items-center gap-3">
            <span class="text-orange-700"><Check size={20} /></span>
            Semantic Translation Memory
          </h3>
          <p class="text-stone-600 font-sans leading-relaxed text-sm">
            Upload your old TMX files or start fresh. Our TM doesn't just match
            words; it uses high-dimensional vector embeddings to understand the
            exact context and tone of previous translations, injecting them
            directly into the LLM prompt.
          </p>
        </div>

        <div class="bg-white p-8 rounded-sm border border-stone-200 shadow-sm">
          <h3 class="font-serif text-xl mb-3 flex items-center gap-3">
            <span class="text-orange-700"><Check size={20} /></span>
            Document Parsing
          </h3>
          <p class="text-stone-600 font-sans leading-relaxed text-sm">
            Drag and drop DOCX, PDF, XLIFF, or Subtitle files. Our proprietary
            parser strips the structural skeleton, translates the semantic
            content, and perfectly rebuilds the document format without breaking
            variables or tags.
          </p>
        </div>

        <div class="bg-white p-8 rounded-sm border border-stone-200 shadow-sm">
          <h3 class="font-serif text-xl mb-3 flex items-center gap-3">
            <span class="text-orange-700"><Check size={20} /></span>
            Brand Voice Control
          </h3>
          <p class="text-stone-600 font-sans leading-relaxed text-sm">
            Create custom Brand Voices with negative constraints and strict
            instructions. Ensure the AI never uses hyperbolic marketing language
            and always adheres to your specific corporate tone.
          </p>
        </div>

        <div class="bg-white p-8 rounded-sm border border-stone-200 shadow-sm">
          <h3 class="font-serif text-xl mb-3 flex items-center gap-3">
            <span class="text-orange-700"><Check size={20} /></span>
            Team Workspaces
          </h3>
          <p class="text-stone-600 font-sans leading-relaxed text-sm">
            Invite your developers, marketers, and linguists to a shared
            workspace. Share Translation Memories and Glossaries across the
            entire organization instantly.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <Section
    data-chapter="04 — INVITATION"
    class="content-section bg-stone-900 text-white py-24"
  >
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-4xl mb-6">
        Claim your Early Adopter Allocation.
      </h2>
      <p
        class="text-stone-400 font-sans mb-10 max-w-xl mx-auto leading-relaxed"
      >
        Beta testers receive prioritizing routing and a heavily subsidized
        initial character pool to thoroughly evaluate the system. Help us build
        the definitive AI translation infrastructure.
      </p>

      <a href={openBetaLink} class="hidden">
        Enter Workspace <ArrowRight size={20} />
      </a>

      <p
        class="text-xs text-stone-500 font-mono mt-6 uppercase tracking-widest"
      >
        No credit card required for Beta access.
      </p>
    </div>
  </Section>
</BaseLayout>
