---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Section from "../../../components/ui/Section.astro";
import Breadcrumbs from "../../../components/seo/Breadcrumbs.astro";
import TldrBlock from "../../../components/seo/TldrBlock.astro";
import FAQSection from "../../../components/seo/FAQSection.astro";
import SchemaOrg from "../../../components/seo/SchemaOrg.astro";
import HeroProjectManagement from "../../../components/visuals/HeroProjectManagement.jsx";
import { getLocalizedPath, locales } from "../../../i18n/utils";

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    ...locales.map((lang) => ({ params: { lang } })),
  ];
}

let { lang } = Astro.params;
if (!lang) lang = "en";

const title = "Project Management | Flixu";
const description =
  "Streamline your AI localization pipeline with Flixu's built-in project management workspace. Track progress, files, and contextual scopes.";

const breadcrumbItems = [
  { name: "Home", url: getLocalizedPath("/", lang) },
  { name: "Features", url: getLocalizedPath("/features", lang) },
  { name: "Project Management", url: Astro.url.pathname },
];

const faqs = [
  {
    question: "Does Flixu have built-in project management for translation?",
    answer:
      "Yes, Flixu includes a comprehensive project workspace. You can organize source files via folders, assign clients, track word counts, and monitor translation completion status across multiple target languages.",
  },
  {
    question: "Can I share translation projects with my team?",
    answer:
      "Yes, in Team and Business plans, projects can be shared across your workspace. You can utilize role-based access control (Admin, Editor, Viewer) to restrict actions.",
  },
  {
    question: "Can I mix multiple file types in a single project?",
    answer:
      "Absolutely. You can drop a DOCX whitepaper, a JSON app file, and SRT subtitles into the same project folder. The AI applies the selected Brand Voice consistently across all of them.",
  },
  {
    question: "How does the AI Quality Score assist human reviewers?",
    answer:
      "The Quality Score algorithm mathematically estimates the confidence of the LLM output. It flags potentially problematic segments with low scores so human reviewers know exactly which sentences to focus on, dramatically reducing Q/A time.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      name: "Flixu Project Management",
      applicationCategory: "BusinessApplication",
      operatingSystem: "Web",
    },
    {
      "@type": "FAQPage",
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    },
  ],
};
---

<BaseLayout title={title} description={description}>
  <SchemaOrg schema={schema} slot="schema" />

  <Section data-chapter="01 — OVERVIEW" class="hero-section pb-16">
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center max-w-7xl mx-auto px-6"
    >
      <div class="max-w-3xl !px-0">
        <Breadcrumbs items={breadcrumbItems} />
        <span
          class="font-mono text-xs text-orange-700 uppercase tracking-widest mb-6 block"
          >Feature Spotlight</span
        >
        <h1 class="mb-6">The Localization Workspace.</h1>
        <p class="max-w-2xl text-xl text-stone-600 mb-8">
          Manage source files, assign contexts, and track progress without
          jumping between spreadsheets and external tools.
        </p>
        <a href={`/${lang !== "en" ? lang + "/" : ""}pricing`} class="hidden">
          Centralize Your Projects
        </a>
      </div>
      <div class="relative w-full aspect-[4/3] hidden lg:block">
        <HeroProjectManagement client:load />
      </div>
    </div>
  </Section>

  <Section data-chapter="02 — TL;DR" class="tldr-section">
    <div class="max-w-3xl">
      <TldrBlock
        text="Flixu provides a dedicated Project Dashboard designed for localization teams and freelancers. Group multiple files (DOCX, SRT, PO, XLIFF) into unified projects, instantly apply a specific Client Profile to bind the correct Brand Voice and Glossary, and track character usage precisely across target locales with integrated Quality Scoring summaries."
      />
    </div>
  </Section>

  <Section data-chapter="03 — CAPABILITIES" class="content-section mt-12">
    <div class="max-w-3xl">
      <h2 class="mb-12">How does Flixu streamline localization pipelines?</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="flex flex-col gap-4">
          <div
            class="w-10 h-10 flex items-center justify-center bg-orange-50 text-orange-700 rounded-sm mb-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="18" height="18" x="3" y="3" rx="2" ry="2"
              ></rect><line x1="9" x2="15" y1="12" y2="12"></line><line
                x1="12"
                x2="12"
                y1="9"
                y2="15"></line></svg
            >
          </div>
          <h3 class="text-xl">Multi-File Batching</h3>
          <p class="text-stone-600 leading-relaxed">
            Drag and drop large localization packages. Flixu parses document
            structures (XML, PO, Markdown) simultaneously within the project
            scope.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <div
            class="w-10 h-10 flex items-center justify-center bg-orange-50 text-orange-700 rounded-sm mb-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path></svg
            >
          </div>
          <h3 class="text-xl">Context Inheritance</h3>
          <p class="text-stone-600 leading-relaxed">
            Assign a client and target formality (e.g., "Formal German") at the
            project level. Every file within inherits these exact contextual
            boundaries for the AI.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <div
            class="w-10 h-10 flex items-center justify-center bg-orange-50 text-orange-700 rounded-sm mb-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polygon
                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
              ></polygon></svg
            >
          </div>
          <h3 class="text-xl">Approval Workflow</h3>
          <p class="text-stone-600 leading-relaxed">
            Track segment-by-segment review status. The built-in AI Quality
            Score rapidly flags low-confidence translations, saving Reviewers
            hours of manual Q/A.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <div
            class="w-10 h-10 flex items-center justify-center bg-orange-50 text-orange-700 rounded-sm mb-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"
              ></path></svg
            >
          </div>
          <h3 class="text-xl">Activity Feed</h3>
          <p class="text-stone-600 leading-relaxed">
            See instantly when a team member modifies a string or accepts a
            translation. All project interactions are logged in a continuous
            team activity stream.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <Section
    data-chapter="04 — FAQ"
    class="content-section bg-stone-50 border-t border-stone-200 mt-24"
  >
    <div class="max-w-3xl mx-auto">
      <FAQSection items={faqs} />
    </div>
  </Section>
</BaseLayout>
