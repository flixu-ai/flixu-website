---
import { getCollection, type CollectionEntry } from "astro:content";
import { getLocalizedPath } from "../../../i18n/utils";

export const prerender = true;

export async function getStaticPaths() {
  const { locales } = await import("../../../i18n/utils");
  return locales.map((l) => ({ params: { lang: l === "en" ? undefined : l } }));
}

let { lang } = Astro.params;
if (!lang) lang = "en";

// Get the first doc for this language sorted by order
const docs = await getCollection("docs");
const localizedDocs = docs.filter((d) => d.id.startsWith("en/"));
const firstDoc = localizedDocs.sort(
  (a: CollectionEntry<"docs">, b: CollectionEntry<"docs">) =>
    a.data.order - b.data.order,
)[0];

const cleanSlug = firstDoc.id
  .replace(new RegExp(`^en/`), "")
  .replace(/\.mdx?$/, "");

return Astro.redirect(getLocalizedPath(`/docs/${cleanSlug}`, lang));
---
