---
// 301 Redirect: Audio Intelligence → Text Translation (feature removed)
export const prerender = true;
import { locales, getLocalizedPath } from "../../../i18n/utils";

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    ...locales.map((lang) => ({ params: { lang } })),
  ];
}
const { lang } = Astro.params;
const target = getLocalizedPath("/product/text", lang);
---

<meta http-equiv="refresh" content={`0; url=${target}`} />
<script define:vars={{ target }}>
  window.location.replace(target);
</script>
