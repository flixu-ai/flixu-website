---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import TldrBlock from "../../components/seo/TldrBlock.astro";
import HeroMethodology from "../../components/visuals/HeroMethodology.jsx";
import { useTranslations, locales, getLocalizedPath } from "../../i18n/utils";

export const prerender = true;

export async function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    ...locales.map((lang) => ({ params: { lang } })),
  ];
}

let { lang } = Astro.params;
if (!lang) lang = "en";

const t = await useTranslations(lang);
const tNav = t.navigation as any;

const breadcrumbItems = [
  { name: tNav?.home?.title || "Home", url: getLocalizedPath("/", lang) },
  { name: tNav?.method?.title || "Method", url: Astro.url.pathname },
];
---

<BaseLayout
  title={`${t.methodPage.hero.title} | Flixu`}
  description={t.methodPage.hero.description}
>
  <!-- HERO SECTION -->
  <Section data-chapter="01 — INTRO" class="hero-section">
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center max-w-7xl mx-auto px-6"
    >
      <div class="hero-container !px-0">
        <Breadcrumbs items={breadcrumbItems} />
        <span
          class="text-orange-600 font-mono text-sm tracking-widest uppercase mb-6 block"
          >{t.methodPage.hero.badge}</span
        >
        <h1>
          {t.methodPage.hero.title}
        </h1>
        <p class="text-xl">
          {t.methodPage.hero.description}
        </p>
      </div>
      <div class="relative w-full aspect-[4/3] hidden lg:block">
        <HeroMethodology client:load />
      </div>
    </div>
  </Section>

  <Section data-chapter="02 — TL;DR" class="tldr-section">
    <div class="max-w-3xl">
      <TldrBlock
        text="Raw LLMs suffer from severe contextual amnesia, causing Terminology Drift and unpredictable translations. The Flixu Method introduces an Orchestration Layer between your source data and the AI. By using Semantic Vector Retrieval (RAG) and active Glossary injection, we force the LLM into deterministic alignment with your Brand Voice—yielding zero-hallucination translations that preserve your code geometry."
      />
    </div>
  </Section>

  <!-- WHAT IS FLIXU -->
  <Section
    data-chapter="03 — CONCEPT"
    class="content-section border-b border-stone-100"
  >
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="mb-6">
          {t.methodPage.whatIsFlixu.title}
        </h2>
      </div>
      <div class="space-y-6">
        <p>
          {t.methodPage.whatIsFlixu.copy1}
        </p>
        <p>
          {t.methodPage.whatIsFlixu.copy2}
        </p>
      </div>
    </div>
  </Section>

  <!-- ARCHITECTURE -->
  <Section
    data-chapter="04 — ARCHITECTURE"
    class="content-section border-b border-stone-100 bg-stone-50"
  >
    <div class="max-w-3xl mb-16">
      <h2 class="mb-4">
        {t.methodPage.architecture.title}
      </h2>
      <p
        class="text-orange-600 font-mono text-sm tracking-widest uppercase mb-6"
      >
        {t.methodPage.architecture.subtitle}
      </p>
      <p>
        {t.methodPage.architecture.intro}
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        t.methodPage.architecture.points.map((point: string, i: number) => {
          const [title, desc] = point.split(":");
          const isLast = i === 6;

          return (
            <div
              class={`group relative bg-white p-8 border border-stone-200 transition-all duration-300 hover:border-stone-300 hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] ${isLast ? "md:col-span-2 lg:col-span-3 flex flex-col md:flex-row md:items-center gap-6 md:gap-10" : ""}`}
            >
              <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-orange-400 to-[#b52a1c] opacity-0 group-hover:opacity-100 transition-opacity" />

              <div class={isLast ? "md:w-1/3 shrink-0" : ""}>
                <div class="text-[#b52a1c] font-mono text-xs mb-3 font-semibold tracking-widest">
                  LAYER {i + 1}
                </div>
                <h3 class="mb-2">{title}</h3>
              </div>

              <div
                class={isLast ? "md:border-l md:border-stone-200 md:pl-10" : ""}
              >
                <p>{desc}</p>
              </div>
            </div>
          );
        })
      }
    </div>
  </Section>

  <!-- QUALITY (PRECISION TM) -->
  <Section
    data-chapter="05 — QUALITY"
    class="content-section border-b border-stone-100"
  >
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="mb-4">
          {t.methodPage.quality.title}
        </h2>
        <p class="text-orange-600 font-mono text-sm tracking-widest uppercase">
          {t.methodPage.quality.subtitle}
        </p>
      </div>
      <div class="space-y-6">
        <p>
          {t.methodPage.quality.copy1}
        </p>
        <p>
          {t.methodPage.quality.copy2}
        </p>
      </div>
    </div>
  </Section>

  {
    lang === "en" && (
      <Section
        data-chapter="06 — DEEP DIVE"
        class="content-section border-b border-stone-100"
      >
        <div class="max-w-3xl mx-auto prose prose-stone prose-p:text-stone-600 prose-headings:text-stone-900 prose-headings:font-light">
          <h2>The Flixu Method: Engineering Context as Code</h2>
          <p>
            A common misconception in the software industry is the belief that
            raw Large Language Models (LLMs) have fully solved international
            translation. Developers routinely wire a basic API call to OpenAI or
            Anthropic, feed it a raw JSON file of English UI strings, and assume
            the localization process is complete.
          </p>
          <p>However, this approach quickly introduces scale constraints.</p>
          <p>
            Raw LLMs operate without persistent context. If the model is not
            explicitly instructed on the exact, proprietary terminology your
            enterprise utilizes, the AI defaults to generic, colloquial synonym
            generation. It might translate "Dashboard" accurately on Monday, but
            on Thursday, arbitrarily translate the same string as "Control
            Panel" or "Interface." In professional B2B software, terminology
            inconsistency erodes user trust and can significantly impact the
            customer experience.
          </p>

          <h3>Why Prompt Engineering Cannot Scale</h3>
          <p>
            When teams realize raw LLMs are failing, they attempt to solve the
            issue through manual prompt engineering. They append increasingly
            complex text instructions to every API call: *"Respond formally. Do
            not translate the word 'Space'. Remember that we are a B2B SaaS
            company for dentists."*
          </p>
          <p>
            Prompt engineering is fundamentally unscalable. It relies on the
            fragile intuition of individual developers. It fractures rapidly
            when multiple departments (Marketing, Legal, Product) require
            entirely different tones for the exact same language. Furthermore,
            hardcoding prompt rules directly into the codebase creates
            significant technical debt every time the corporate branding
            guidelines evolve.
          </p>

          <h2>Deterministic Orchestration Over Stochastic Generation</h2>
          <p>
            The Flixu Method represents a fundamental architectural departure
            from raw AI generation. We do not expose you directly to an LLM;
            instead, we position a highly structured, mathematically
            deterministic Orchestration Layer between your source data and the
            inference engine.
          </p>
          <p>
            We call this <strong>Context Injection</strong>.
          </p>
          <p>
            When your CI/CD pipeline sends a payload to Flixu, our Orchestration
            Layer intercepts it. Before generating a single word of translation,
            Flixu actively queries your isolated Translation Memory (TM)
            database via Semantic Vector Retrieval (RAG). It extracts any
            previously approved, historically perfect translations that match
            the current context. Simultaneously, it pulls your strict corporate
            Glossary rules and your specific Brand Voice parameters (e.g.,
            Target Formality: "Strict/Sie").
          </p>
          <p>
            Flixu then seamlessly injects this comprehensive, mathematically
            validated context matrix into the LLM inference prompt dynamically.
            The AI is structurally constrained. It isn’t guessing how to
            translate your proprietary features; it is executing a highly
            restrictive algorithm. The output is no longer a stochastic
            hallucination—it is a deterministic operational truth.
          </p>

          <h3>Preserving the Geometry of Code</h3>
          <p>
            Beyond semantic correctness, the Flixu Method explicitly addresses
            Structural Geometry. Translating an abstract idea is entirely
            different from translating an HTML string containing localized
            `href` links, inline `&lt;span class="text-red-500"&gt;` styling,
            and backend `&#123;userId&#125;` variables.
          </p>
          <p>
            Raw LLMs frequently corrupt code structure. They translate variable
            logic (breaking the backend) or delete closing HTML tags (corrupting
            the frontend UI). The Flixu Orchestration Layer utilizes custom
            masking parsers that actively separate the linguistic content from
            the code geometry. The AI translates the pure semantics, and Flixu
            reconstructs the code structure exactly as the developer engineered
            it, ensuring absolute code safety upon deployment.
          </p>
          <p>
            <strong>
              The Flixu Method is simple: You provide the text. We engineer the
              context. The algorithm enforces precise consistency.
            </strong>
          </p>
        </div>
      </Section>
    )
  }

  <!-- CTA -->
  <Section data-chapter="07 — START" class="content-section text-center">
    <h2 class="mb-10">
      {t.methodPage.cta.title}
    </h2>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://app.flixu.ai/register"
        class="px-8 py-4 bg-[#b52a1c] text-white rounded hover:bg-[#9a2318] transition-colors text-sm font-medium w-full sm:w-auto"
      >
        {t.methodPage.cta.primary}
      </a>
      <a
        href="mailto:enterprise@flixu.ai"
        class="px-8 py-4 bg-stone-100 text-stone-900 rounded hover:bg-stone-200 transition-colors text-sm font-medium w-full sm:w-auto"
      >
        {t.methodPage.cta.secondary}
      </a>
    </div>
  </Section>
</BaseLayout>
