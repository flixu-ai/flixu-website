---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import TldrBlock from "../../components/seo/TldrBlock.astro";
import FAQSection from "../../components/seo/FAQSection.astro";
import SchemaOrg from "../../components/seo/SchemaOrg.astro";
import HeroMethodology from "../../components/visuals/HeroMethodology.jsx";
import { useTranslations, locales, getLocalizedPath } from "../../i18n/utils";

export const prerender = true;

export async function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    ...locales.map((lang) => ({ params: { lang } })),
  ];
}

let { lang } = Astro.params;
if (!lang) lang = "en";

const t = await useTranslations(lang);
const tNav = t.navigation as any;

const breadcrumbItems = [
  { name: tNav?.home?.title || "Home", url: getLocalizedPath("/", lang) },
  { name: tNav?.method?.title || "Method", url: Astro.url.pathname },
];

// FAQ items for FAQSection component
const faqItems = t.methodPage.faq.items.map((item) => ({
  question: item.question,
  answer: item.answer,
}));

// HowTo + BreadcrumbList schema
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: t.methodPage.hero.title,
  description: t.methodPage.hero.description,
  step: t.methodPage.architecture.steps.map((step, i) => ({
    "@type": "HowToStep",
    position: i + 1,
    name: step.title,
    text: step.body,
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.name,
    item: `https://flixu.ai${item.url}`,
  })),
};

// Step type for the architecture section
type Step = {
  num: string;
  title: string;
  body: string;
  linkText?: string;
  linkHref?: string;
  linkText2?: string;
  linkHref2?: string;
};
---

<BaseLayout
  title={t.methodPage.metaTitle}
  description={t.methodPage.metaDescription}
  chapter="Method"
>
  <Fragment slot="schema">
    <SchemaOrg schema={howToSchema} />
    <SchemaOrg schema={breadcrumbSchema} />
  </Fragment>

  <!-- SECTION 1 — HERO -->
  <Section data-chapter="01 — INTRO" class="hero-section">
    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 lg:gap-24 items-center"
    >
      <div>
        <Breadcrumbs items={breadcrumbItems} />
        <span
          class="text-orange-700 font-mono text-xs tracking-widest uppercase mb-6 block"
          >{t.methodPage.hero.badge}</span
        >
        <h1
          class="font-serif text-4xl md:text-6xl text-stone-900 mb-8 tracking-tight leading-[1.1]"
        >
          {t.methodPage.hero.title}
        </h1>
        <p class="text-xl text-stone-500 leading-relaxed">
          {t.methodPage.hero.description}
        </p>
      </div>
      <div class="relative w-full aspect-[4/3] hidden md:block">
        <HeroMethodology client:load />
      </div>
    </div>
  </Section>

  <!-- SECTION 2 — TL;DR -->
  <Section data-chapter="02 — TL;DR" class="tldr-section">
    <div class="max-w-3xl">
      <TldrBlock text={t.methodPage.tldr.text} label={t.methodPage.tldr.label} />
    </div>
  </Section>

  <!-- SECTION 3 — CONCEPT -->
  <Section
    data-chapter="03 — CONCEPT"
    class="py-24 bg-[#FDFCF8] border-b border-stone-200"
  >
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="font-serif text-3xl lg:text-4xl text-stone-900 leading-tight">
          {t.methodPage.concept.h2}
        </h2>
      </div>
      <div class="space-y-6">
        <p class="text-stone-600 leading-relaxed">
          {t.methodPage.concept.p1}
        </p>
        <p class="text-stone-600 leading-relaxed">
          {t.methodPage.concept.p2}
        </p>
        <a
          href={getLocalizedPath(t.methodPage.concept.linkHref, lang)}
          class="text-orange-700 hover:text-orange-800 text-sm font-medium transition-colors inline-block mt-2"
        >
          → {t.methodPage.concept.linkText}
        </a>
      </div>
    </div>
  </Section>

  <!-- SECTION 4 — ARCHITECTURE (HowTo Steps) -->
  <Section
    data-chapter="04 — ARCHITECTURE"
    class="py-24 bg-paper border-b border-stone-200"
  >
    <div class="max-w-3xl mb-16">
      <h2 class="font-serif text-3xl lg:text-4xl text-stone-900 mb-4">
        {t.methodPage.architecture.h2}
      </h2>
      <span class="text-orange-700 font-mono text-xs tracking-widest uppercase mb-6 block">
        {t.methodPage.architecture.badge}
      </span>
      <p class="text-stone-600 leading-relaxed">
        {t.methodPage.architecture.intro}
      </p>
    </div>

    <!-- Steps -->
    <div class="space-y-12 max-w-3xl">
      {t.methodPage.architecture.steps.map((step: Step) => (
        <div class="pl-8 border-l-2 border-stone-200">
          <div class="text-orange-700 font-mono text-xs font-semibold tracking-widest mb-3">
            STEP {step.num}
          </div>
          <h3 class="font-serif text-xl text-stone-900 mb-4">{step.title}</h3>
          <p class="text-stone-600 leading-relaxed">{step.body}</p>
          {step.linkText && step.linkHref && (
            <a
              href={getLocalizedPath(step.linkHref, lang)}
              class="text-orange-700 hover:text-orange-800 text-sm font-medium transition-colors inline-block mt-4"
            >
              → {step.linkText}
            </a>
          )}
          {step.linkText2 && step.linkHref2 && (
            <a
              href={getLocalizedPath(step.linkHref2, lang)}
              class="text-orange-700 hover:text-orange-800 text-sm font-medium transition-colors block mt-2"
            >
              → {step.linkText2}
            </a>
          )}
        </div>
      ))}
    </div>

    <!-- 5-Dimensions Table (after Step 3) -->
    <div class="max-w-4xl mt-16">
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-stone-300">
              {t.methodPage.architecture.dimensions.headers.map((h: string) => (
                <th class="text-left py-3 px-4 font-mono text-xs text-orange-700 uppercase tracking-widest">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {t.methodPage.architecture.dimensions.rows.map((row: string[]) => (
              <tr class="border-b border-stone-100">
                <td class="py-3 px-4 font-medium text-stone-900">{row[0]}</td>
                <td class="py-3 px-4 text-stone-600">{row[1]}</td>
                <td class="py-3 px-4 text-stone-600">{row[2]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </Section>

  <!-- SECTION 5 — LEARNING LOOP -->
  <Section
    data-chapter="05 — LEARNING"
    class="py-24 bg-[#FDFCF8] border-b border-stone-200"
  >
    <div class="max-w-3xl">
      <h2 class="font-serif text-3xl lg:text-4xl text-stone-900 mb-8 leading-tight">
        {t.methodPage.learning.h2}
      </h2>
      <div class="space-y-6 text-stone-600 leading-relaxed">
        <p>{t.methodPage.learning.p1}</p>
        <p>{t.methodPage.learning.p2}</p>
      </div>
    </div>
  </Section>

  <!-- SECTION 6 — COMPARISON TABLE -->
  <Section
    data-chapter="06 — COMPARISON"
    class="py-24 bg-paper border-b border-stone-200"
  >
    <div class="max-w-4xl">
      <h2 class="font-serif text-3xl lg:text-4xl text-stone-900 mb-12">
        {t.methodPage.comparison.h2}
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-stone-300">
              {t.methodPage.comparison.headers.map((h: string) => (
                <th class="text-left py-3 px-4 font-mono text-xs text-orange-700 uppercase tracking-widest">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {t.methodPage.comparison.rows.map((row: string[]) => (
              <tr class="border-b border-stone-100">
                <td class="py-3 px-4 font-medium text-stone-900 whitespace-nowrap">{row[0]}</td>
                <td class="py-3 px-4 text-stone-500">{row[1]}</td>
                <td class="py-3 px-4 text-stone-500">{row[2]}</td>
                <td class="py-3 px-4 text-stone-900 font-medium">{row[3]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-stone-500 text-sm leading-relaxed mt-8">
        {t.methodPage.comparison.note}
      </p>
      <a
        href={getLocalizedPath(t.methodPage.comparison.linkHref, lang)}
        class="text-orange-700 hover:text-orange-800 text-sm font-medium transition-colors inline-block mt-4"
      >
        → {t.methodPage.comparison.linkText}
      </a>
    </div>
  </Section>

  <!-- SECTION 7 — FAQ -->
  <Section
    data-chapter="07 — FAQ"
    class="py-24 bg-[#FDFCF8] border-b border-stone-200"
  >
    <div class="max-w-3xl">
      <FAQSection items={faqItems} title={t.methodPage.faq.title} />

      <!-- FAQ deep links -->
      <div class="mt-6 space-y-3">
        {t.methodPage.faq.items
          .filter((item) => item.linkHref)
          .map((item) => (
            <a
              href={getLocalizedPath(item.linkHref!, lang)}
              class="text-orange-700 hover:text-orange-800 text-xs font-medium transition-colors block"
            >
              → {item.linkText}
            </a>
          ))
        }
      </div>
    </div>
  </Section>

  <!-- SECTION 8 — CTA -->
  <Section
    data-chapter="08 — START"
    class="py-24 bg-paper text-center"
  >
    <div class="max-w-2xl mx-auto">
      <h2 class="font-serif text-3xl lg:text-4xl text-stone-900 mb-10">
        {t.methodPage.cta.h2}
      </h2>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={getLocalizedPath("/signup", lang)}
          class="px-8 py-4 bg-orange-700 text-white rounded-sm hover:bg-orange-800 transition-colors text-sm font-medium w-full sm:w-auto hidden"
        >
          {t.methodPage.cta.primary}
        </a>
        <a
          href="mailto:founders@flixu.ai"
          class="px-8 py-4 bg-stone-100 text-stone-900 rounded-sm hover:bg-stone-200 transition-colors text-sm font-medium w-full sm:w-auto"
        >
          {t.methodPage.cta.secondary}
        </a>
      </div>
    </div>
  </Section>

  <!-- AUTHOR BLOCK -->
  <Section class="py-12 bg-[#FDFCF8]">
    <div class="max-w-2xl mx-auto">
      <div class="pt-8 border-t border-stone-100 flex items-start gap-4">
        <div
          class="w-12 h-12 bg-stone-100 rounded-full overflow-hidden grayscale relative shrink-0"
        >
          <span
            class="absolute inset-0 flex items-center justify-center font-serif italic text-stone-400 text-lg"
            >D</span
          >
        </div>
        <div>
          <div class="font-serif text-lg text-stone-900 italic">
            {t.methodPage.author.name}
          </div>
          <div class="font-mono text-xs text-orange-700 uppercase tracking-widest mt-1">
            {t.methodPage.author.role}
          </div>
          <p class="text-sm text-stone-500 mt-3 leading-relaxed font-sans">
            {t.methodPage.author.bio}{" "}
            <a
              href={getLocalizedPath(t.methodPage.author.bioLinkHref, lang)}
              class="text-orange-700 hover:text-orange-800 underline decoration-orange-200 underline-offset-2 transition-colors"
            >
              {t.methodPage.author.bioLinkText}</a>.
          </p>
        </div>
      </div>
      <div class="mt-8 text-xs text-stone-400 font-mono uppercase tracking-widest">
        Last Updated: {t.methodPage.author.lastUpdated}
      </div>
    </div>
  </Section>
</BaseLayout>
