---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";
import OutlineCard from "../../components/ui/OutlineCard.astro";
import HeroAmbient from "../../components/homepage/HeroAmbient.astro";
import TranslationWidget from "../../components/widget/TranslationWidget.jsx";
import WorkspaceVisual from "../../components/widget/WorkspaceVisual.jsx";
import TranslationComparator from "../../components/widget/TranslationComparator.jsx";
import SchemaOrg from "../../components/seo/SchemaOrg.astro";
import {
  Cpu,
  BookMarked,
  ArrowRight,
  Globe,
  FileText,
  Layers,
  Image,
  Mic,
  Sparkles,
  X,
  Check
} from "lucide-react";
import { useTranslations, locales, getLocalizedPath } from "../../i18n/utils";

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: undefined } }, // Root (English default)
    ...locales.map((lang) => ({ params: { lang } })),
  ];
}

let { lang } = Astro.params;
if (!lang) lang = "en";

const t = await useTranslations(lang);

const iconMap = {
  Cpu,
  Globe,
  BookMarked,
  FileText,
  Layers,
  Image,
  Mic,
  ArrowRight,
};

const LogicIcon1 = iconMap[t.logic.c1.icon as keyof typeof iconMap];
const LogicIcon2 = iconMap[t.logic.c2.icon as keyof typeof iconMap];
const LogicIcon3 = iconMap[t.logic.c3.icon as keyof typeof iconMap];

const isDev = import.meta.env.DEV;
const appUrl = isDev ? "http://localhost:3000" : "https://app.flixu.ai";

// Organization + SoftwareApplication schema
const homepageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Flixu",
    url: "https://flixu.ai",
    logo: "https://flixu.ai/flixu-favicon.svg",
    description:
      "Context-aware AI translation platform. Orchestrates LLMs with glossaries, translation memory, and brand voice to deliver precise multilingual content.",
    founder: {
      "@type": "Person",
      name: "Deniz Wozniak",
    },
    sameAs: ["https://www.linkedin.com/company/flixu"],
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Flixu",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://flixu.ai",
    description:
      "AI translation workspace with context awareness, glossary enforcement, translation memory, and brand voice consistency.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "EUR",
      description: "Free tier available",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "What is Flixu?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Flixu is a context-aware AI translation workspace for global product teams. It bridges the gap between raw AI APIs and enterprise translation platforms.",
        },
      },
      {
        "@type": "Question",
        name: "Does Flixu maintain my brand voice?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Yes. Flixu injects 7 layers of context—including Brand Voice, Glossaries, and Translation Memory—into every translation payload.",
        },
      },
    ],
  },
];
---

<BaseLayout title={t.hero.metaTitle}>
  <Fragment slot="schema">
    {homepageSchema.map((schema) => <SchemaOrg schema={schema} />)}
  </Fragment>

  <!-- HERO SECTION -->
  <Section
    id="start"
    data-chapter={`01 — ${t.rail.intro.toUpperCase()}`}
    class="pt-16 md:pt-24 pb-16 lg:pb-24 border-b border-stone-200 relative overflow-hidden bg-paper"
  >
    <HeroAmbient />
    <div class="relative z-10 w-full">
      <!-- HERO GRID -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- LEFT TEXT -->
        <div class="max-w-xl">
          <div
            class="inline-block px-3 py-1 mb-8 rounded-full border border-stone-200 bg-stone-50 text-[10px] font-mono tracking-widest uppercase text-stone-500"
          >
            {t.hero.badgeLabel}
          </div>

          <h1 class="text-4xl lg:text-5xl xl:text-6xl font-serif tracking-tight mb-6 text-stone-900" set:html={t.hero.h1} />

          <p class="mb-12">
            {t.hero.sub}
          </p>

          <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
            <a
              href={`${appUrl}/sign-up?plan=individual&intent=individual&interval=month`}
              class="px-8 py-4 rounded-sm bg-orange-700 text-white hover:bg-orange-800 transition-colors flex items-center gap-2 group"
            >
              <span class="font-medium">{t.hero.btnPrimary}</span>
              <ArrowRight
                size={18}
                className="group-hover:translate-x-1 transition-transform"
              />
            </a>
            <a
              href="#demo"
              class="px-8 py-4 rounded-sm border border-stone-200 text-stone-600 hover:border-stone-400 hover:text-stone-900 transition-colors bg-white"
            >
              {t.hero.btnSecondary}
            </a>
          </div>

          <p
            class="mt-4 text-xs text-stone-500 font-mono flex items-center gap-2"
          >
            <span class="block w-1.5 h-1.5 rounded-full bg-green-500"></span>
            {t.hero.badge}
          </p>
        </div>

        <!-- RIGHT PREVIEW UI -->
        <div class="relative w-full aspect-[4/3] lg:aspect-video flex items-center justify-center">
           <!-- Decorative Background Element -->
           <div class="absolute inset-0 bg-stone-100 rounded-full blur-3xl opacity-50 z-0 scale-90"></div>
           
           <div class="relative border border-stone-200 rounded-lg shadow-2xl overflow-hidden bg-white w-full h-fit flex items-center justify-center z-10 rotate-1 hover:rotate-0 transition-transform duration-500 ease-out">
             <div class="absolute inset-0 bg-stone-50 flex items-center justify-center text-stone-400 font-mono text-xs uppercase tracking-widest z-0">
                UI Preview Placeholder
             </div>
             <img src="/assets/flixu-workspace-preview.jpg" alt="Flixu AI Translation Workspace Preview" class="object-cover w-full opacity-90 hover:opacity-100 transition-opacity relative z-10" />
           </div>
        </div>
      </div>

      <!-- TRUST BAR -->
      <div
        class="mt-4 pt-4 border-t border-stone-200 w-full flex flex-col md:flex-row items-center gap-4 md:gap-8 opacity-80 grayscale mix-blend-multiply"
      >
        <span
          class="text-[10px] font-mono uppercase tracking-widest text-stone-500 shrink-0 mb-4 md:mb-0"
        >
          {t.home?.accelerated || "Accelerated by & Member of"}
        </span>
        <div class="flex items-center gap-8 md:gap-12 w-full overflow-hidden flex-wrap">
          <span
            class="font-sans font-bold text-lg tracking-tight text-stone-800"
            >NVIDIA INCEPTION</span
          >
          <span
            class="font-sans font-bold text-lg tracking-tight text-stone-800"
            >Google for Startups</span
          >
        </div>
      </div>
    </div>
  </Section>

  <!-- MISSING MIDDLE SECTION (Moved up) -->
  <Section
    data-chapter="02 — THE MISSING MIDDLE"
    class="py-32 border-b border-stone-200 bg-paper"
  >
    <div class="max-w-5xl mx-auto">
      <div class="mb-16 max-w-3xl">
        <span class="font-mono text-xs tracking-widest text-orange-700 uppercase mb-4 block">The Problem</span>
        <h2 class="mb-6">Serving the Missing Middle of B2B Localization.</h2>
        <p class="text-stone-600 text-lg">
          For a decade, the translation industry has been fractured into two
          extremes. The market forces growing SaaS companies into a difficult
          choice between generic, context-blind automation or slow, highly complex
          human workflows.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Raw AI Card -->
        <div class="p-8 border border-stone-200 bg-white rounded-sm shadow-sm flex flex-col">
          <div class="font-mono text-xs text-stone-400 mb-6 uppercase tracking-widest border-b border-stone-100 pb-4">The Low End</div>
          <h3 class="text-xl mb-4 text-stone-900">Raw AI APIs</h3>
          <p class="text-stone-600 mb-6 text-sm flex-grow">
            Tools like Google Translate and DeepL provide instantaneous generation at low costs. However, they lack contextual architecture.
          </p>
          <ul class="text-sm text-stone-500 space-y-3 mt-auto">
            <li class="flex items-center gap-2"><span class="text-red-500">✕</span> No Glossary enforcement</li>
            <li class="flex items-center gap-2"><span class="text-red-500">✕</span> Robotic, homogenous tone</li>
            <li class="flex items-center gap-2"><span class="text-red-500">✕</span> Zero translation memory</li>
          </ul>
        </div>

        <!-- Flixu Card (The Missing Middle) -->
        <div class="p-8 border-2 border-orange-700 bg-white rounded-sm shadow-md flex flex-col relative transform md:-translate-y-4">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-orange-700 text-white text-[10px] uppercase tracking-widest font-mono px-3 py-1 rounded-full whitespace-nowrap">The Missing Middle</div>
          <div class="font-mono text-xs text-orange-700 mb-6 uppercase tracking-widest border-b border-stone-100 pb-4">Flixu Context Engine</div>
          <h3 class="text-xl mb-4 text-stone-900">Stateful Intelligence</h3>
          <p class="text-stone-700 mb-6 text-sm flex-grow font-medium">
            The instant, scalable speed of a raw API, combined inextricably with the rigorous brand compliance mechanics of an enterprise platform.
          </p>
          <ul class="text-sm text-stone-700 space-y-3 mt-auto font-medium">
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> 7-Layer Context Injection</li>
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> Programmable Brand Voice</li>
            <li class="flex items-center gap-2"><span class="text-green-600">✓</span> CI/CD developer ready</li>
          </ul>
        </div>

        <!-- Legacy TMS Card -->
        <div class="p-8 border border-stone-200 bg-white rounded-sm shadow-sm flex flex-col">
          <div class="font-mono text-xs text-stone-400 mb-6 uppercase tracking-widest border-b border-stone-100 pb-4">The High End</div>
          <h3 class="text-xl mb-4 text-stone-900">Legacy TMS</h3>
          <p class="text-stone-600 mb-6 text-sm flex-grow">
            Traditional enterprise platforms provide control, but require a 9-month integration project and complex agency review cycles.
          </p>
          <ul class="text-sm text-stone-500 space-y-3 mt-auto">
            <li class="flex items-center gap-2"><span class="text-red-500">✕</span> Blocks CI/CD velocity</li>
            <li class="flex items-center gap-2"><span class="text-red-500">✕</span> Bureaucratic workflows</li>
            <li class="flex items-center gap-2"><span class="text-red-500">✕</span> Bloated pricing structures</li>
          </ul>
        </div>
      </div>
    </div>
  </Section>

  <!-- TRUST & TESTIMONIALS SECTION (Visible for now) -->
  <Section
    id="trust"
    data-chapter="03 — TRUST & VALIDATION"
    class="py-32 border-b border-stone-200 bg-paper"
  >
    <div class="max-w-5xl mx-auto w-full text-center">
      <span class="font-mono text-xs tracking-widest text-orange-700 uppercase mb-4 block">Beta Tester Voices</span>
      <h2 class="mb-16">Trusted by Localization Managers.</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
        <!-- Placeholder Testimonial 1 -->
        <div class="p-8 border border-stone-200 bg-white shadow-sm rounded-sm">
          <p class="text-stone-600 mb-6 italic">"Awaiting real beta tester feedback on glossary enforcement..."</p>
          <div class="flex items-center gap-3">
             <div class="w-10 h-10 bg-stone-200 rounded-full"></div>
             <div>
               <div class="font-bold text-sm text-stone-900">Name Pending</div>
               <div class="text-xs text-stone-500">Localization Manager, B2B SaaS</div>
             </div>
          </div>
        </div>
        <!-- Placeholder Testimonial 2 -->
        <div class="p-8 border border-stone-200 bg-white shadow-sm rounded-sm">
          <p class="text-stone-600 mb-6 italic">"Awaiting real beta tester feedback on TM retrieval..."</p>
          <div class="flex items-center gap-3">
             <div class="w-10 h-10 bg-stone-200 rounded-full"></div>
             <div>
               <div class="font-bold text-sm text-stone-900">Name Pending</div>
               <div class="text-xs text-stone-500">Head of Growth, Startup</div>
             </div>
          </div>
        </div>
        <!-- Placeholder Testimonial 3 -->
        <div class="p-8 border border-stone-200 bg-white shadow-sm rounded-sm">
          <p class="text-stone-600 mb-6 italic">"Awaiting real beta tester feedback on Brand Voice..."</p>
          <div class="flex items-center gap-3">
             <div class="w-10 h-10 bg-stone-200 rounded-full"></div>
             <div>
               <div class="font-bold text-sm text-stone-900">Name Pending</div>
               <div class="text-xs text-stone-500">Lead Translator, Agency</div>
             </div>
          </div>
        </div>
      </div>
    </div>
  </Section>
  
  <!-- QUALITY COMPARISON TOGGLE SECTION (Visible for now) -->
  <Section
    id="comparison"
    data-chapter="04 — QUALITY COMPARATOR"
    class="py-32 border-b border-stone-200 bg-paper"
  >
    <div class="max-w-5xl mx-auto w-full">
      <div class="text-center mb-16">
        <span class="font-mono text-xs tracking-widest text-orange-700 uppercase mb-4 block">Before & After</span>
        <h2>The Context Difference.</h2>
        <p class="text-stone-600 max-w-2xl mx-auto">Toggle between raw, context-blind APIs and Flixu's 7-layer context architecture.</p>
      </div>
      
      <!-- Interactive Comparison Container -->
      <TranslationComparator client:visible />
    </div>
  </Section>

  <!-- WIDGET SECTION (Restored) -->
  <Section
    id="demo"
    data-chapter={`05 — ${t.rail.preview.toUpperCase()}`}
    class="py-32 border-b border-stone-200 bg-paper"
  >
    <div class="mb-16 max-w-5xl mx-auto w-full">
      <div class="max-w-2xl">
        <span
          class="font-mono text-xs tracking-widest text-orange-700 uppercase mb-4 block"
          >{t.widget.label}</span
        >
        <h2>
          {t.widget.h2}
        </h2>
        <p>
          {t.widget.sub}
        </p>
      </div>
    </div>

    <div class="w-full">
      <TranslationWidget client:load t={t.widget} />
    </div>
  </Section>

  <Section
    data-chapter={`06 — ${t.rail.manifesto.toUpperCase()}`}
    class="py-32 bg-paper"
  >
    <div class="max-w-3xl mx-auto text-center">
      <span class="font-serif italic text-stone-500 text-xl mb-8 block"
        >A note on craft.</span
      >
      <h2
        class="font-handwriting text-xl md:text-2xl text-stone-800 leading-relaxed mb-10"
      >
        "Flixu wasn’t created in a boardroom. It was born on the road—somewhere
        between client calls and spotty signal. I spent months translating for
        clients, switching between AI tools that were fast but blind to context,
        and human workflows that were precise but unscalable.<br /><br />
        The frustration was clear: If translation doesn’t feel human, it doesn’t work.<br
        /><br />
        We built Flixu to close that gap. To build a quiet, precise workspace that
        respects language in all its complexity."
      </h2>
      <div class="flex justify-center items-center gap-4">
        <div class="h-px w-12 bg-stone-300"></div>
        <span class="font-mono text-xs uppercase tracking-widest text-stone-500"
          >The Founder</span
        >
        <div class="h-px w-12 bg-stone-300"></div>
      </div>
    </div>
  </Section>

  <!-- SEO & AIO KNOWLEDGE BASE SECTION -->
  <Section class="py-32 bg-paper border-b border-stone-200">
    <div class="max-w-5xl mx-auto w-full">
      <div class="max-w-3xl mb-16">
        <span class="font-mono text-xs tracking-widest text-orange-700 uppercase mb-4 block">Platform Overview</span>
        <h2 class="text-3xl lg:text-4xl font-serif mb-6 text-stone-900">What is Context-Aware AI Translation?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16">
        <div>
          <p class="text-stone-600 text-lg leading-relaxed mb-8">
        Context-aware AI translation is an advanced localization methodology that analyzes the entire document structure, brand voice guidelines, and corporate glossaries before generating translated text. Unlike traditional machine translation APIs that process text sentence-by-sentence in isolation, context-aware engines like Flixu load up to seven layers of metadata into a Large Language Model (LLM) payload to ensure consistency and precision.
          </p>
          
          <h3 class="font-serif text-2xl mt-8 mb-4 text-stone-900">Why Raw AI Fails at B2B Localization</h3>
          <p class="text-stone-600 leading-relaxed mb-8">
            Generic APIs provided by major tech companies are highly efficient for consumer translation, but they lack the stateful memory required for enterprise software deployment. When a B2B SaaS company pushes an update, the terminology must perfectly match the existing UI glossaries. Raw AI models cannot enforce these glossaries natively, leading to terminology drift and degraded user trust in international markets.
          </p>

          <h3 class="font-serif text-2xl mt-8 mb-4 text-stone-900">The Role of Translation Memory in AI</h3>
          <p class="text-stone-600 leading-relaxed mb-8">
            Translation Memory (TM) has been the foundation of the localization industry for decades. By combining legacy TM architecture with modern Vector Database retrieval, Flixu ensures that past human-approved translations always take precedence over AI generation. This Retrieval-Augmented Generation (RAG) approach drastically reduces the need for human review cycles, cutting localization QA time by up to 80%.
          </p>
        </div>
        
        <div>
          <h2 class="font-serif text-3xl mb-8 mt-0 border-b border-stone-200 pb-4 text-stone-900">Frequently Asked Questions</h2>
          <div class="space-y-6">
            <div>
              <h4 class="font-bold text-stone-900 mb-2 font-sans">How does Flixu preserve brand voice?</h4>
              <p class="text-sm text-stone-600">Flixu allows organizations to define programmable brand voice profiles. These tone instructions—such as formality level, dynamic constraints, and stylistic preferences—are injected directly into the LLM context window during translation.</p>
            </div>
            <div>
              <h4 class="font-bold text-stone-900 mb-2 font-sans">Which file formats does the document translator support?</h4>
              <p class="text-sm text-stone-600">The Flixu engine supports structural layout preservation for highly technical formats including XLIFF, DOCX, Markdown, XML, and software localization files like PO/POT and iOS .strings.</p>
            </div>
            <div>
              <h4 class="font-bold text-stone-900 mb-2 font-sans">Is context-aware translation faster than traditional TMS platforms?</h4>
              <p class="text-sm text-stone-600">Yes. While legacy Translation Management Systems (TMS) require complex agency onboarding and weeks of human review, Flixu executes terminology-perfect translations in milliseconds natively within your CI/CD pipeline.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
