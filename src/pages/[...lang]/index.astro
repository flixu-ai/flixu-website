---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/ui/Section.astro";
import HeroAmbient from "../../components/homepage/HeroAmbient.astro";
import TranslationComparator from "../../components/widget/TranslationComparator.jsx";
import TldrBlock from "../../components/seo/TldrBlock.astro";
import FAQSection from "../../components/seo/FAQSection.astro";
import SchemaOrg from "../../components/seo/SchemaOrg.astro";
import { ArrowRight } from "lucide-react";
import { useTranslations, locales, getLocalizedPath } from "../../i18n/utils";

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    ...locales.map((lang) => ({ params: { lang } })),
  ];
}

let { lang } = Astro.params;
if (!lang) lang = "en";

const t = await useTranslations(lang);

const isDev = import.meta.env.DEV;
const appUrl = isDev ? "http://localhost:3000" : "https://app.flixu.ai";

// Build FAQ items for the FAQSection component (plain text only, no links)
const faqItems = t.home.faq.items.map((item: { question: string; answer: string }) => ({
  question: item.question,
  answer: item.answer,
}));

// Organization + SoftwareApplication + FAQPage schema
const homepageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Flixu",
    url: "https://flixu.ai",
    logo: "https://flixu.ai/flixu-favicon.svg",
    description:
      "Context-aware AI translation platform. Orchestrates LLMs with glossaries, translation memory, and brand voice to deliver precise multilingual content.",
    founder: {
      "@type": "Person",
      name: "Deniz Wozniak",
    },
    sameAs: ["https://www.linkedin.com/company/flixu"],
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Flixu",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://flixu.ai",
    description:
      "AI translation workspace with context awareness, glossary enforcement, translation memory, and brand voice consistency.",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "EUR",
      description: "Free tier available",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: t.home.faq.items.map(
      (item: { question: string; answer: string }) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })
    ),
  },
];
---

<BaseLayout
  title={t.hero.metaTitle}
  description={t.hero.metaDescription}
>
  <Fragment slot="schema">
    {homepageSchema.map((schema) => <SchemaOrg schema={schema} />)}
  </Fragment>

  <!-- SECTION 1 — HERO -->
  <Section
    id="start"
    data-chapter={`01 — ${t.rail.intro.toUpperCase()}`}
    class="pt-16 md:pt-24 pb-16 lg:pb-24 relative overflow-hidden bg-paper"
  >
    <HeroAmbient />
    <div class="relative z-10 w-full">
      <!-- HERO CONTENT — Single Column, Centered -->
      <div class="max-w-3xl mx-auto text-center">
          <div
            class="inline-block px-3 py-1 mb-8 rounded-full border border-stone-200 bg-stone-50 text-[10px] font-mono tracking-widest uppercase text-stone-500"
          >
            {t.hero.badgeLabel}
          </div>

          <h1 class="text-4xl lg:text-5xl xl:text-6xl font-serif tracking-tight mb-6 text-stone-900">
            {t.hero.h1}
          </h1>

          <p class="mb-12 text-lg text-stone-600">
            {t.hero.sub}
          </p>

          <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
            <a
              href={`${appUrl}/sign-up?plan=individual&intent=individual&interval=month`}
              class="px-8 py-4 rounded-sm bg-orange-700 text-white hover:bg-orange-800 transition-colors flex items-center gap-2 group hidden"
            >
              <span class="font-medium">{t.hero.btnPrimary}</span>
              <ArrowRight
                size={18}
                className="group-hover:translate-x-1 transition-transform"
              />
            </a>
            <a
              href="#comparison"
              class="px-8 py-4 rounded-sm border border-stone-200 text-stone-600 hover:border-stone-400 hover:text-stone-900 transition-colors bg-white"
            >
              {t.hero.btnSecondary}
            </a>
          </div>

          <p
            class="mt-6 text-xs text-stone-500 font-mono flex items-center gap-2 justify-center"
          >
            <span class="block w-1.5 h-1.5 rounded-full bg-green-500"></span>
            {t.hero.badge}
          </p>
      </div>

      <!-- TRUST BAR -->
      <div
        class="mt-8 pt-4 border-t border-stone-200 max-w-xl mx-auto flex flex-col items-center gap-3 opacity-80 grayscale mix-blend-multiply"
      >
        <span
          class="text-[10px] font-mono uppercase tracking-widest text-stone-500"
        >
          {t.home.accelerated}
        </span>
        <div class="flex items-center justify-center gap-8">
          <span
            class="font-sans font-bold text-lg tracking-tight text-stone-800"
            >{t.home.nvidiaInception}</span
          >
          <span
            class="font-sans font-bold text-lg tracking-tight text-stone-800"
            >{t.home.googleStartups}</span
          >
        </div>
      </div>
    </div>
  </Section>

  <!-- TL;DR / ANSWER-FIRST BLOCK -->
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-10">
    <TldrBlock label={t.home.tldr.label} text={t.home.tldr.text} />
  </div>

  <!-- SECTION 2 — THE MISSING MIDDLE -->
  <Section
    data-chapter="02 — THE MISSING MIDDLE"
    class="py-32 border-b border-stone-200 bg-paper"
  >
    <div class="w-full">
      <div class="mb-16 max-w-3xl">
        <span class="font-mono text-xs tracking-widest text-orange-700 uppercase mb-4 block">{t.home.missingMiddle.preTitle}</span>
        <h2 class="mb-6">{t.home.missingMiddle.h2}</h2>
        <p class="text-stone-600 text-lg">
          {t.home.missingMiddle.intro}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1 — Low End -->
        <div class="p-8 border border-stone-200 bg-white rounded-sm shadow-sm flex flex-col">
          <div class="font-mono text-xs text-stone-400 mb-6 uppercase tracking-widest border-b border-stone-100 pb-4">{t.home.missingMiddle.lowEnd.label}</div>
          <h3 class="text-xl mb-4 text-stone-900">{t.home.missingMiddle.lowEnd.h3}</h3>
          <p class="text-stone-600 mb-6 text-sm flex-grow">
            {t.home.missingMiddle.lowEnd.p}
          </p>
          <ul class="text-sm text-stone-500 space-y-3 mt-auto">
            {t.home.missingMiddle.lowEnd.specs.map((spec: string) => (
              <li class="flex items-center gap-2"><span class="text-red-500">✕</span> {spec}</li>
            ))}
          </ul>
        </div>

        <!-- Card 2 — Flixu (Highlighted) -->
        <div class="p-8 border-2 border-orange-700 bg-white rounded-sm shadow-md flex flex-col relative transform md:-translate-y-4">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-orange-700 text-white text-[10px] uppercase tracking-widest font-mono px-3 py-1 rounded-full whitespace-nowrap">The Missing Middle</div>
          <div class="font-mono text-xs text-orange-700 mb-6 uppercase tracking-widest border-b border-stone-100 pb-4">{t.home.missingMiddle.flixu.label}</div>
          <h3 class="text-xl mb-4 text-stone-900">{t.home.missingMiddle.flixu.h3}</h3>
          <p class="text-stone-700 mb-6 text-sm flex-grow font-medium">
            {t.home.missingMiddle.flixu.p}
          </p>
          <ul class="text-sm text-stone-700 space-y-3 mt-auto font-medium">
            {t.home.missingMiddle.flixu.specs.map((spec: string) => (
              <li class="flex items-center gap-2"><span class="text-green-600">✓</span> {spec}</li>
            ))}
          </ul>
        </div>

        <!-- Card 3 — High End -->
        <div class="p-8 border border-stone-200 bg-white rounded-sm shadow-sm flex flex-col">
          <div class="font-mono text-xs text-stone-400 mb-6 uppercase tracking-widest border-b border-stone-100 pb-4">{t.home.missingMiddle.highEnd.label}</div>
          <h3 class="text-xl mb-4 text-stone-900">{t.home.missingMiddle.highEnd.h3}</h3>
          <p class="text-stone-600 mb-6 text-sm flex-grow">
            {t.home.missingMiddle.highEnd.p}
          </p>
          <ul class="text-sm text-stone-500 space-y-3 mt-auto">
            {t.home.missingMiddle.highEnd.specs.map((spec: string) => (
              <li class="flex items-center gap-2"><span class="text-red-500">✕</span> {spec}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </Section>

  <!-- SECTION 3 — TRUST & TESTIMONIALS -->
  <Section
    id="trust"
    data-chapter="03 — TRUST & VALIDATION"
    class="py-32 border-b border-stone-200 bg-paper"
  >
    <div class="w-full">
      <span class="font-mono text-xs tracking-widest text-orange-700 uppercase mb-4 block">{t.home.trust.preTitle}</span>
      <h2 class="mb-16">{t.home.trust.h2}</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
        {t.home.trust.cards.map((card: { quote: string; name: string; role: string }) => (
          <div class="p-8 border border-stone-200 bg-white shadow-sm rounded-sm">
            <p class="text-stone-600 mb-6 italic">"{card.quote}"</p>
            <div class="flex items-center gap-3">
               <div class="w-10 h-10 bg-stone-200 rounded-full"></div>
               <div>
                 <div class="font-bold text-sm text-stone-900">{card.name}</div>
                 <div class="text-xs text-stone-500">{card.role}</div>
               </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>
  
  <!-- SECTION 4 — QUALITY COMPARATOR -->
  <Section
    id="comparison"
    data-chapter="04 — QUALITY COMPARATOR"
    class="py-32 border-b border-stone-200 bg-paper"
  >
    <div class="w-full">
      <div class="mb-16">
        <span class="font-mono text-xs tracking-widest text-orange-700 uppercase mb-4 block">{t.home.comparator.preTitle}</span>
        <h2 class="mb-6">{t.home.comparator.h2}</h2>
        <p class="text-stone-600 max-w-2xl">{t.home.comparator.p}</p>
      </div>
      
      <TranslationComparator client:visible />
    </div>
  </Section>

  <!-- SECTION 5 — MANIFESTO -->
  <Section
    data-chapter={`05 — ${t.rail.manifesto.toUpperCase()}`}
    class="py-32 border-b border-stone-200 bg-paper"
  >
    <div class="max-w-3xl mx-auto text-center">
      <span class="font-serif italic text-stone-500 text-xl mb-8 block"
        >{t.home.manifesto.label}</span
      >
      <h2
        class="font-handwriting text-xl md:text-2xl text-stone-800 leading-relaxed mb-10"
      >
        "{t.home.manifesto.quote}"
      </h2>
      <div class="flex justify-center items-center gap-4">
        <div class="h-px w-12 bg-stone-300"></div>
        <span class="font-mono text-xs uppercase tracking-widest text-stone-500"
          >{t.home.manifesto.signoff}</span
        >
        <div class="h-px w-12 bg-stone-300"></div>
      </div>
    </div>
  </Section>

  <!-- SECTION 6 — PLATFORM KNOWLEDGE / FAQ -->
  <Section
    data-chapter="06 — SEO & AIO KNOWLEDGE BASE"
    class="py-32 bg-paper border-b border-stone-200"
  >
    <div class="w-full">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16 items-start">
        <!-- Left Column — Capability Breakdown -->
        <div>
          <span class="font-mono text-xs tracking-widest text-orange-700 uppercase mb-4 block">{t.home.platform.preTitle}</span>
          <h2 class="text-3xl lg:text-4xl font-serif mb-12 text-stone-900">{t.home.platform.h2}</h2>
          {t.home.platform.capabilities.map((cap: { h3: string; p: string; linkText: string; linkHref: string }) => (
            <div class="mb-10">
              <h3 class="font-serif text-2xl mt-8 mb-4 text-stone-900">{cap.h3}</h3>
              <p class="text-stone-600 leading-relaxed mb-4">
                {cap.p}
              </p>
              <a href={getLocalizedPath(cap.linkHref, lang)} class="text-orange-700 hover:text-orange-800 text-sm font-medium transition-colors">
                → {cap.linkText}
              </a>
            </div>
          ))}
        </div>
        
        <!-- Right Column — FAQ -->
        <div>
          <FAQSection items={faqItems} title={t.home.faq.title} />

          <!-- FAQ items with optional deep links -->
          <div class="mt-6 space-y-3">
            {t.home.faq.items
              .filter((item) => item.linkHref)
              .map((item) => (
                <a
                  href={getLocalizedPath(item.linkHref!, lang)}
                  class="text-orange-700 hover:text-orange-800 text-xs font-medium transition-colors block"
                >
                  → {item.linkText}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- FOOTER CTA -->
  <Section class="py-20 bg-paper">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-stone-600 text-lg mb-6">{t.home.footerCta.text}</p>
      <a
        href={`${appUrl}/sign-up?plan=individual&intent=individual&interval=month`}
        class="inline-flex items-center gap-2 px-8 py-4 rounded-sm bg-orange-700 text-white hover:bg-orange-800 transition-colors group hidden"
      >
        <span class="font-medium">{t.home.footerCta.cta}</span>
        <ArrowRight
          size={18}
          className="group-hover:translate-x-1 transition-transform"
        />
      </a>
    </div>
  </Section>
</BaseLayout>
